{
  "manifest_version": 3,
  "name": "actions.json Overlay Runtime",
  "version": "0.1.196",
  "description": "Experimental actions.json runtime that can render agent-provided HTML overlays on authorized tabs.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "actions.json Overlay Runtime"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "debugger",
    "offscreen",
    "scripting",
    "storage",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "actions/overlay.actions.json",
        "sidepanel.html",
        "src/sidepanel.js",
        "src/storage-bundle.mjs",
        "src/agent/*.mjs",
        "src/agent/vendor/*.mjs"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
