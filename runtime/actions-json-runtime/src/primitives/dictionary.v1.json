{
  "version": 1,
  "stage": 1,
  "primitives": [
    {
      "name": "browser.screenshot",
      "version": 1,
      "stage": 1,
      "summary": "Capture a true rendered screenshot where the host has browser-level authority.",
      "capability_class": "privileged",
      "portable": false,
      "capabilities": ["browser.screenshot"],
      "input_schema": {
        "type": "object",
        "properties": {
          "format": { "type": "string", "enum": ["png", "jpeg"] },
          "quality": { "type": "integer", "minimum": 1, "maximum": 100 },
          "max_width": { "type": "integer", "minimum": 1 },
          "max_height": { "type": "integer", "minimum": 1 },
          "max_kilobytes": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["image"],
        "properties": {
          "image": { "type": "string" },
          "mime_type": { "type": "string" },
          "width": { "type": "integer" },
          "height": { "type": "integer" }
        }
      },
      "adapters": {
        "extension": { "support": "supported" },
        "embed": { "support": "unsupported", "reason": "capability_unavailable" }
      },
      "errors": ["capability_unavailable", "capture_failed"],
      "conformance": { "fixture": null, "assertions": ["structured_result_or_capability_error"] }
    },
    {
