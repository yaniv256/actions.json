{
  "protocol": "actions.json",
  "version": 1,
  "surface": {
    "origin": "file://examples/simple-form/index.html",
    "kind": "contact_form",
    "description": "A simple contact form example."
  },
  "imports": [],
  "prompt": {
    "title": "Contact form",
    "instructions": "Use the contact form action to fill and submit the name field.",
    "state_summary": "The form is ready when the name field, submit button, and result output are visible.",
    "source": {
      "files": [
        "index.html"
      ],
      "selectors": [
        "#contact-form",
        "#name",
        "#submit",
        "#result"
      ],
      "component": "ContactForm"
    }
  },
  "context": [
    {
      "id": "contact.form.context",
      "title": "Contact form state",
      "body": "This page has one form. The agent should verify that the name field, submit button, and result output are visible before submitting.",
      "load_when": {
        "states": [
          "form_ready"
        ],
        "targets": [
          "#contact-form"
        ]
      },
      "available_tools": [
        "contact.submit_name"
      ],
      "next_states": [
        "form_submitted"
      ],
      "source": {
        "files": [
          "index.html"
        ],
        "selectors": [
          "#contact-form",
          "#name",
          "#submit",
          "#result"
        ]
      }
    }
  ],
  "states": [
    {
      "name": "form_ready",
      "description": "The contact form is visible and can accept a name submission.",
      "diagnostics": [
        {
          "name": "name_field_visible",
          "target": {
            "selector": "#name",
            "role": "textbox",
            "name": "Name",
            "fallback_selectors": [
              "input[name='name']"
            ]
          }
        },
        {
          "name": "submit_button_visible",
          "target": {
            "selector": "#submit",
            "role": "button",
            "name": "Submit",
            "fallback_selectors": [
              "button[type='submit']"
            ]
          }
        }
      ],
      "observables": [
        "name_field_visible",
        "submit_button_visible",
        "result_output_visible"
      ]
    },
    {
      "name": "form_submitted",
      "description": "The result output contains a submitted-name confirmation.",
      "diagnostics": [
        {
          "name": "result_contains_submitted",
          "target": {
            "selector": "#result",
            "text_contains": "Submitted"
          }
        }
      ],
      "observables": [
        "result_text"
      ]
    }
  ],
  "transitions": [
    {
      "name": "submit_contact_form",
      "tool": "contact.submit_name",
      "from": "form_ready",
      "to": "form_submitted",
      "method": "tool_call",
      "preconditions": [
        "name_is_present",
        "form_ready"
      ],
      "reveals": [
        "result_text"
      ],
      "convergence": {
        "complete_when": "result_text_contains_submitted_name",
        "max_attempts": 1
      }
    }
  ],
  "tools": [
    {
      "name": "contact.submit_name",
      "description": "Fill the contact form name field and submit the form.",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "target": {
        "selector": "#contact-form",
        "role": "form",
        "name": "Contact form",
        "state": "form_ready",
        "fallback_selectors": [
          "main form",
          "form"
        ]
      },
      "x_actions": {
        "direction": "agent_to_html",
        "handler": "contactForm.submitName",
        "scope": "active_surface",
        "state_machine": {
          "initial_state": "form_ready",
          "terminal_state": "form_submitted",
          "diagnostics": [
            "name_field_visible",
            "submit_button_visible",
            "result_contains_submitted"
          ],
          "transitions": [
            "submit_contact_form"
          ]
        },
        "source": {
          "files": [
            "index.html"
          ],
          "symbols": [
            "contactForm.submitName"
          ],
          "selectors": [
            "#contact-form",
            "#name",
            "#submit",
            "#result"
          ],
          "component": "ContactForm"
        },
        "execution": {
          "mode": "handler_first",
          "fallback": "steps_on_missing_handler_or_drift",
          "steps": [
            {
              "id": "inspect_name_input",
              "type": "inspect",
              "target": {
                "selector": "#name",
                "role": "textbox",
                "name": "Name"
              },
              "assert": {
                "visible": true,
                "enabled": true
              }
            },
            {
              "id": "type_name",
              "type": "type",
              "target": {
                "selector": "#name"
              },
              "value_from": "name"
            },
            {
              "id": "click_submit",
              "type": "click",
              "target": {
                "selector": "#submit",
                "role": "button",
                "name": "Submit"
              }
            },
            {
              "id": "wait_for_result",
              "type": "wait",
              "until": {
                "selector": "#result",
                "text_contains": "Submitted"
              },
              "timeout_ms": 2000
            },
            {
              "id": "extract_result",
              "type": "extract",
              "target": {
                "selector": "#result"
              },
              "as": "result"
            }
          ]
        },
        "result_schema": {
          "type": "object",
          "properties": {
            "ok": {
              "type": "boolean"
            },
            "result": {
              "type": "string"
            }
          },
          "required": [
            "ok"
          ]
        }
      }
    }
  ],
  "signals": [
    {
      "name": "contact.submitted",
      "description": "Emitted when the simple form submit handler updates the result output.",
      "direction": "html_to_agent",
      "event": "contact:submitted",
      "ingestion": "enabled",
      "target": {
        "selector": "#result",
        "state": "form_submitted"
      },
      "payload": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "result"
        ],
        "additionalProperties": false
      },
      "protocol": {
        "responses": {
          "item_type": "dom_event",
          "correlation": {
            "event_id": "generated_by_runtime",
            "previous_call_id": "optional"
          }
        }
      },
      "source": {
        "files": [
          "index.html"
        ],
        "symbols": [
          "contact:submitted"
        ],
        "selectors": [
          "#contact-form",
          "#result"
        ],
        "component": "ContactForm"
      }
    }
  ],
  "attachments": [
    {
      "id": "contact-result-status",
      "kind": "status_badge",
      "description": "Optional runtime-owned status badge attached to the result output.",
      "target": {
        "selector": "#result",
        "state": "form_ready",
        "fallback_selectors": [
          "output"
        ]
      },
      "affordance": {
        "label": "actions.json",
        "title": "This form is mapped by actions.json",
        "placement": "afterend",
        "max_instances": 1
      },
      "lifecycle": {
        "install": "when_target_matches",
        "remove": "when_context_mismatch",
        "reattach": "on_url_or_dom_change",
        "drift": "emit_signal_and_hide_affordance"
      },
      "signals": {
        "attached": "attachment.attached",
        "reattached": "attachment.reattached",
        "drifted": "attachment.drifted"
      }
    }
  ],
  "checks": [
    {
      "id": "simple_form_targets_exist",
      "description": "The simple form has the expected input, submit button, and result output.",
      "severity": "major",
      "setup": [
        {
          "type": "navigate",
          "url": "examples/simple-form/index.html"
        }
      ],
      "assertions": [
        {
          "target": {
            "selector": "#name"
          },
          "visible": true
        },
        {
          "target": {
            "selector": "#submit"
          },
          "visible": true
        },
        {
          "target": {
            "selector": "#result"
          },
          "visible": true
        }
      ],
      "on_fail": {
        "store_evidence": [
          "url",
          "dom_snapshot"
        ],
        "contingency": "use_alternate_selectors_or_handoff_to_user",
        "alternate_selectors": [
          "input[name='name']",
          "button[type='submit']",
          "output"
        ]
      }
    },
    {
      "id": "simple_form_submit_flow",
      "description": "Submitting a name reaches the form_submitted state and returns a result.",
      "severity": "major",
      "setup": [
        {
          "type": "navigate",
          "url": "examples/simple-form/index.html"
        }
      ],
      "steps": [
        {
          "type": "call",
          "tool": "contact.submit_name",
          "arguments": {
            "name": "Ada"
          }
        }
      ],
      "expected_result": {
        "ok": true,
        "result_contains": "Submitted Ada"
      },
      "on_fail": {
        "store_evidence": [
          "url",
          "dom_snapshot"
        ],
        "contingency": "handoff_to_user"
      }
    }
  ],
  "provenance": {
    "created_from": [
      "actions.json schema v1",
      "ACT-5 schema implementation path"
    ],
    "created_by": "codex",
    "updated_at": "2026-06-02"
  }
}
